NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/memoryvault

JWT_SECRET=replace_with_a_long_secure_secret
JWT_EXPIRES_IN=7d
JWT_ISSUER=memoryvault-api
JWT_AUDIENCE=memoryvault-client
JWT_TREE_ACCESS_AUDIENCE=memoryvault-tree-access
TREE_ACCESS_TOKEN_TTL=20m

CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret

EMAIL_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=MemoryVault <no-reply@example.com>

MAX_UPLOAD_SIZE_MB=5
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=25
PAYMENT_RATE_LIMIT_WINDOW_MS=900000
PAYMENT_RATE_LIMIT_MAX=120
REQUEST_SLOW_THRESHOLD_MS=1200
