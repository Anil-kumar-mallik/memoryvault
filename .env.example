# MemoryVault root environment template
# Copy this file to `.env` and adjust values.

NODE_ENV=production
PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/memoryvault

JWT_SECRET=your_super_long_random_secret_here
JWT_EXPIRES_IN=7d
JWT_ISSUER=memoryvault-api
JWT_AUDIENCE=memoryvault-client
JWT_TREE_ACCESS_AUDIENCE=memoryvault-tree-access
TREE_ACCESS_TOKEN_TTL=20m

CLIENT_URL=https://your-frontend-url.com
FRONTEND_URL=https://your-frontend-url.com

RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

EMAIL_ENABLED=true
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your_resend_api_key
EMAIL_FROM=MemoryVault <onboarding@resend.dev>

RESEND_VERIFIED_DOMAIN=
ALLOW_UNVERIFIED_LOGIN=false

MAX_UPLOAD_SIZE_MB=5
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=25
PAYMENT_RATE_LIMIT_WINDOW_MS=900000
PAYMENT_RATE_LIMIT_MAX=120
REQUEST_SLOW_THRESHOLD_MS=1200

NEXT_PUBLIC_API_URL=https://your-backend-url/api/v1
NEXT_PUBLIC_UPLOADS_URL=https://your-backend-url