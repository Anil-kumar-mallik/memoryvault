# MemoryVault root environment template
# Copy this file to `.env` and adjust values for your deployment.

# -----------------------------
# Server configuration
# -----------------------------
NODE_ENV=production
PORT=5000
MONGO_URI=mongodb://mongodb:27017/memoryvault

JWT_SECRET=8d91c20e173c0f14bb036748f3b1f3cf9c441cb32353e0b71a751788416ab088aecc777944d3d775e0711715def08ff1ffd27e99a3f3af14a8b4efc2feb2740d
JWT_EXPIRES_IN=7d
JWT_ISSUER=memoryvault-api
JWT_AUDIENCE=memoryvault-client
JWT_TREE_ACCESS_AUDIENCE=memoryvault-tree-access
TREE_ACCESS_TOKEN_TTL=20m

CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret
EMAIL_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=MemoryVault <no-reply@example.com>
RESEND_VERIFIED_DOMAIN=
ALLOW_UNVERIFIED_LOGIN=false

MAX_UPLOAD_SIZE_MB=5
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=25
PAYMENT_RATE_LIMIT_WINDOW_MS=900000
PAYMENT_RATE_LIMIT_MAX=120
REQUEST_SLOW_THRESHOLD_MS=1200

# -----------------------------
# Client configuration
# -----------------------------
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_UPLOADS_URL=http://localhost:5000
